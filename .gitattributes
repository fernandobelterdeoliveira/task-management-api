# Normalize text files in the repository to LF.
* text=auto eol=lf

# Java and project source files
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.svg text eol=lf

# Shell scripts should use LF.
*.sh text eol=lf

# Windows scripts should use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Maven wrapper executable should use LF.
mvnw text eol=lf
mvnw.cmd text eol=crlf

# Binary files
*.jar binary
*.war binary
*.ear binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
